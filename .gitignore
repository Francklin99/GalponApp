## Ignore Visual Studio temporary files, build results, and user-specific settings

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Re]leases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017/2019/2022 cache directory
.vs/

# MSTest test Results
[Tt]est[Rr]esults/
[Cc]overage/

# JetBrains Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/

# MacOS files
.DS_Store
