<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:GalponApp.Domain.Models"
             x:Class="GalponApp.Presentation.Views.FeedCalculatorPage"
             Title="{Binding Title}"
             BackgroundColor="#F4F6F4">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryGreen">#2E7D32</Color>
            <Color x:Key="SecondaryBrown">#8D6E63</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">
            
            <!-- Selector de Lote Activo -->
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource CardBackground}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Padding="16" Spacing="10">
                    <Label Text="Selección de Lote para Simulación" FontSize="15" FontAttributes="Bold" TextColor="#2E7D32" />
                    
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Lote *" FontSize="12" TextColor="#475569" FontAttributes="Bold" />
                        <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                            <Picker ItemsSource="{Binding Batches}" 
                                    SelectedItem="{Binding SelectedBatch}" 
                                    ItemDisplayBinding="{Binding Name}" 
                                    FontSize="14" 
                                    TextColor="#1E293B" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Resumen del lote elegido -->
                    <HorizontalStackLayout Spacing="10" IsVisible="{Binding SelectedBatch, Converter={x:Null}, ConverterParameter='notnull'}">
                        <Label Text="Edad actual:" FontSize="12" TextColor="#64748B" />
                        <Label Text="{Binding SelectedBatch.AgeInWeeks, StringFormat='{0} semanas'}" FontSize="12" FontAttributes="Bold" TextColor="#1E293B" />
                        <Label Text="•" TextColor="#CBD5E1" />
                        <Label Text="Peso actual:" FontSize="12" TextColor="#64748B" />
                        <Label Text="{Binding SelectedBatch.CurrentWeight, StringFormat='{0:F1} kg'}" FontSize="12" FontAttributes="Bold" TextColor="#2E7D32" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Parámetros de Costos e Ingresos -->
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource CardBackground}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Padding="16" Spacing="14">
                    <Label Text="Parámetros Financieros y de Crianza" FontSize="15" FontAttributes="Bold" TextColor="{StaticResource SecondaryBrown}" />

                    <!-- Costo de compra y costo alimento -->
                    <Grid ColumnDefinitions="*, *">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                            <Label Text="Costo Compra c/u ($)" FontSize="11" TextColor="#475569" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                                <Entry Keyboard="Numeric" Text="{Binding CostPerAnimalString}" FontSize="14" TextColor="#1E293B" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                            <Label Text="Costo Alimento / kg ($)" FontSize="11" TextColor="#475569" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                                <Entry Keyboard="Numeric" Text="{Binding FeedCostPerKgString}" FontSize="14" TextColor="#1E293B" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Otros costos y Precio de Venta -->
                    <Grid ColumnDefinitions="*, *">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                            <Label Text="Otros Gastos Lote ($)" FontSize="11" TextColor="#475569" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                                <Entry Keyboard="Numeric" Text="{Binding OtherCostsString}" FontSize="14" TextColor="#1E293B" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                            <Label Text="Precio Venta Proyectado ($)" FontSize="11" TextColor="#475569" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                                <Entry Keyboard="Numeric" Text="{Binding SalePriceString}" FontSize="14" TextColor="#1E293B" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Metas de Peso y Edad -->
                    <Grid ColumnDefinitions="*, *">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" Margin="0,0,6,0">
                            <Label Text="Peso Objetivo (kg)" FontSize="11" TextColor="#475569" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                                <Entry Keyboard="Numeric" Text="{Binding TargetWeightString}" FontSize="14" TextColor="#1E293B" />
                            </Border>
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" Margin="6,0,0,0">
                            <Label Text="Edad Objetivo (Semanas)" FontSize="11" TextColor="#475569" FontAttributes="Bold" />
                            <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1" Padding="8,2">
                                <Entry Keyboard="Numeric" Text="{Binding TargetAgeWeeksString}" FontSize="14" TextColor="#1E293B" />
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Modo de venta (Kilo vs Unidad) -->
                    <Grid ColumnDefinitions="*, Auto" Margin="0,4,0,0">
                        <VerticalStackLayout Grid.Column="0" Spacing="2">
                            <Label Text="Vender por Peso Vivo (kg)" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label Text="Desactiva para vender por cabeza entera" FontSize="11" TextColor="#64748B" />
                        </VerticalStackLayout>
                        <Switch Grid.Column="1" IsToggled="{Binding SaleIsPerKg}" OnColor="{StaticResource PrimaryGreen}" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Botón de Simulación -->
            <Button Text="🧮 Calcular Rentabilidad y Alimento" 
                    Command="{Binding CalculateCommand}" 
                    BackgroundColor="{StaticResource PrimaryGreen}" 
                    TextColor="White" 
                    FontSize="16" 
                    FontAttributes="Bold" 
                    HeightRequest="50" 
                    CornerRadius="25" />

            <!-- RESULTADOS DEL CALCULO -->
            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource CardBackground}" IsVisible="{Binding HasResult}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.05" />
                </Border.Shadow>
                <VerticalStackLayout Padding="16" Spacing="12">
                    <Label Text="Resultados de la Proyección" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" />
                    
                    <Grid RowDefinitions="Auto, Auto, Auto, Auto, Auto" ColumnDefinitions="*, *" RowSpacing="10" ColumnSpacing="10">
                        <!-- Alimento requerido -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="0">
                            <Label Text="Alimento Total Estimado" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding ResultTotalFeedKg, StringFormat='{0:F1} kg'}" FontSize="15" FontAttributes="Bold" TextColor="#2E7D32" />
                        </VerticalStackLayout>

                        <!-- Costo Alimento -->
                        <VerticalStackLayout Grid.Row="0" Grid.Column="1">
                            <Label Text="Costo de Alimentación" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding ResultTotalFeedCost, StringFormat='${0:F2} USD'}" FontSize="15" FontAttributes="Bold" TextColor="#8D6E63" />
                        </VerticalStackLayout>

                        <!-- Costo producción total -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="0">
                            <Label Text="Costo Total Producción" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding ResultTotalCost, StringFormat='${0:F2} USD'}" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />
                        </VerticalStackLayout>

                        <!-- Ingresos proyectados -->
                        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
                            <Label Text="Ingresos Estimados" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding ResultRevenue, StringFormat='${0:F2} USD'}" FontSize="15" FontAttributes="Bold" TextColor="#0EA5E9" />
                        </VerticalStackLayout>

                        <!-- ROI -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="0">
                            <Label Text="Retorno Inversión (ROI)" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding ResultROI, StringFormat='{0:F1}%'}" FontSize="15" FontAttributes="Bold" TextColor="#7C3AED" />
                        </VerticalStackLayout>

                        <!-- FCR -->
                        <VerticalStackLayout Grid.Row="2" Grid.Column="1">
                            <Label Text="Factor Conversión (FCR)" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding ResultFCR, StringFormat='{0:F2}'}" FontSize="15" FontAttributes="Bold" TextColor="#475569" />
                        </VerticalStackLayout>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,6" />

                    <!-- Utilidad Neta Grande -->
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="UTILIDAD NETA PROYECTADA" FontSize="11" TextColor="#64748B" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="{Binding ResultProfit, StringFormat='${0:F2} USD'}" 
                               FontSize="26" 
                               FontAttributes="Bold" 
                               HorizontalOptions="Center">
                            <Label.Triggers>
                                <!-- Coloreado dinámico según si es ganancia o pérdida -->
                                <DataTrigger TargetType="Label" Binding="{Binding ResultProfit, Converter={x:Null}}" Value="0">
                                    <!-- Fallback -->
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
