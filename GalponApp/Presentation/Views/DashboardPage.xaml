<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GalponApp.Presentation.ViewModels"
             xmlns:controls="clr-namespace:GalponApp.Presentation.Controls"
             x:Class="GalponApp.Presentation.Views.DashboardPage"
             Title="{Binding Title}"
             BackgroundColor="#F4F6F4">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryGreen">#2E7D32</Color>
            <Color x:Key="SecondaryBrown">#8D6E63</Color>
            <Color x:Key="WarningAmber">#FFB300</Color>
            <Color x:Key="ErrorRed">#D32F2F</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout x:Name="MainLayout" Padding="16" Spacing="20">

            <Grid ColumnDefinitions="*, Auto" VerticalOptions="Center">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="Mi Producción" FontSize="13" TextColor="#64748B" FontAttributes="Bold"/>
                    <Label Text="GalponApp Inteligente" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" />
                </VerticalStackLayout>
                <Button Grid.Column="1" 
                        Text="🔄" 
                        FontSize="16" 
                        HeightRequest="40" 
                        WidthRequest="40" 
                        CornerRadius="20" 
                        BackgroundColor="White" 
                        TextColor="{StaticResource PrimaryGreen}" 
                        Command="{Binding LoadStatsCommand}" />
            </Grid>

            <FlexLayout Wrap="Wrap" Direction="Row" JustifyContent="SpaceBetween" AlignContent="Stretch">

                <Border FlexLayout.Basis="48%" FlexLayout.Grow="1" Margin="6" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E9E5" BackgroundColor="{StaticResource CardBackground}">
                    <Grid ColumnDefinitions="Auto, *" Padding="16" ColumnSpacing="16">
                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 12" BackgroundColor="#E8F5E9" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="📈" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Animales totales" FontSize="13" TextColor="#64748B" />
                            <Label Text="{Binding TotalAnimals}" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border FlexLayout.Basis="48%" FlexLayout.Grow="1" Margin="6" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E9E5" BackgroundColor="{StaticResource CardBackground}">
                    <Grid ColumnDefinitions="Auto, *" Padding="16" ColumnSpacing="16">
                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 12" BackgroundColor="#EFEBE9" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="🚀" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Lotes activos" FontSize="13" TextColor="#64748B" />
                            <Label Text="{Binding ActiveBatchesCount}" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border FlexLayout.Basis="48%" FlexLayout.Grow="1" Margin="6" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E9E5" BackgroundColor="{StaticResource CardBackground}">
                    <Grid ColumnDefinitions="Auto, *" Padding="16" ColumnSpacing="16">
                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 12" BackgroundColor="#FFF8E1" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="⚠️" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Alertas" FontSize="13" TextColor="#64748B" />
                            <Label Text="{Binding SickAnimalsCount}" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label Text="Requieren atención" FontSize="11" TextColor="{StaticResource ErrorRed}" Margin="0,2,0,0" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <Border FlexLayout.Basis="48%" FlexLayout.Grow="1" Margin="6" StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E9E5" BackgroundColor="{StaticResource CardBackground}">
                    <Grid ColumnDefinitions="Auto, *" Padding="16" ColumnSpacing="16">
                        <Border Grid.Column="0" WidthRequest="48" HeightRequest="48" StrokeShape="RoundRectangle 12" BackgroundColor="#E0F2F1" StrokeThickness="0" HorizontalOptions="Center" VerticalOptions="Center">
                            <Label Text="➕" FontSize="20" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="Vacunas pendientes" FontSize="13" TextColor="#64748B" />
                            <Label Text="{Binding UpcomingVaccinationsCount}" FontSize="26" FontAttributes="Bold" TextColor="#1E293B" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>
            </FlexLayout>

            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource CardBackground}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.04" />
                </Border.Shadow>
                <Grid Padding="16" ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto" RowSpacing="10">
                    <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="2">
                        <Label Text="Suministro de Alimento Proyectado" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />
                        <Label Text="Estimación de ración requerida para el día de hoy" FontSize="12" TextColor="#64748B" />
                    </VerticalStackLayout>
                    <Label Grid.Row="0" Grid.Column="1" Text="🌾" FontSize="24" VerticalOptions="Center" />

                    <HorizontalStackLayout Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Spacing="24" Margin="0,4,0,0">
                        <VerticalStackLayout>
                            <Label Text="Cantidad Total" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding DailyFeedConsumptionKg, StringFormat='{0:F1} kg'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource PrimaryGreen}" />
                        </VerticalStackLayout>
                        <BoxView WidthRequest="1" HeightRequest="32" Color="#E2E8F0" />
                        <VerticalStackLayout>
                            <Label Text="Costo Estimado" FontSize="11" TextColor="#64748B" />
                            <Label Text="{Binding FeedCostEstimationToday, StringFormat='S/. {0:F2}'}" FontSize="20" FontAttributes="Bold" TextColor="{StaticResource SecondaryBrown}" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>
                </Grid>
            </Border>

            <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" BackgroundColor="#FEF2F2" Stroke="#FCA5A5">
                <VerticalStackLayout Padding="16" Spacing="10">
                    <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                        <Label Text="⚠️" FontSize="16"/>
                        <Label Text="Tareas Críticas de Crianza (Hoy)" FontSize="15" FontAttributes="Bold" TextColor="#991B1B" />
                    </HorizontalStackLayout>

                    <CollectionView ItemsSource="{Binding CriticalAlerts}" EmptyView="¡Todo al día! No hay tareas pendientes para hoy.">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Vertical" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto, *">
                                    <Label Grid.Column="0" Text="• " FontAttributes="Bold" TextColor="#7F1D1D" VerticalOptions="Start"/>
                                    <Label Grid.Column="1" Text="{Binding .}" FontSize="13" TextColor="#7F1D1D" LineBreakMode="WordWrap" />
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="{StaticResource CardBackground}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="4" Opacity="0.04" />
                </Border.Shadow>
                <VerticalStackLayout Padding="16" Spacing="12">
                    <Label Text="Cumplimiento General del Galpón" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />

                    <Grid ColumnDefinitions="*, *" ColumnSpacing="12" HorizontalOptions="Center">
                        <VerticalStackLayout Grid.Column="0" Spacing="4" HorizontalOptions="Center" WidthRequest="110">
                            <controls:CircularProgressControl 
                                Progress="{Binding VaccinationProgress}" 
                                ProgressColor="{StaticResource PrimaryGreen}" 
                                CenterSubtext="Cobertura" 
                                StrokeWidth="6"
                                HeightRequest="70" 
                                WidthRequest="70" />
                            <Label Text="Vacunación" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#475569" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Grid.Column="1" Spacing="4" HorizontalOptions="Center" WidthRequest="110">
                            <controls:CircularProgressControl 
                                Progress="{Binding HealthComplianceProgress}" 
                                ProgressColor="#0EA5E9" 
                                CenterSubtext="Sanos" 
                                StrokeWidth="6"
                                HeightRequest="70" 
                                WidthRequest="70" />
                            <Label Text="Índice Salud" FontSize="11" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#475569" />
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>