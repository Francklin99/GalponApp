<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GalponApp.Presentation.ViewModels"
             xmlns:controls="clr-namespace:GalponApp.Presentation.Controls"
             xmlns:models="clr-namespace:GalponApp.Domain.Models"
             x:Class="GalponApp.Presentation.Views.BatchDetailPage"
             Title="{Binding Title}"
             BackgroundColor="#FFFFFF">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="FarmGreen">#1B4332</Color>
            <Color x:Key="EmeraldMint">#2D6A4F</Color>
            <Color x:Key="LeafGreen">#40916C</Color>
            <Color x:Key="LightMint">#D8F3DC</Color>
            <Color x:Key="WarningOrange">#D97706</Color>
            <Color x:Key="ErrorRed">#E53935</Color>
            <Color x:Key="CardBackground">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Padding="0">

        <Border Grid.Row="0" StrokeThickness="1" Stroke="#F1F5F9" BackgroundColor="White" Padding="16,12">
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Text="←" FontSize="20" FontAttributes="Bold" BackgroundColor="Transparent" TextColor="Black" WidthRequest="40" HeightRequest="40" Command="{Binding GoBackCommand}" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="10,0,0,0">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="{Binding Batch.Name}" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                        <Label Text="-" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                        <Label Text="{Binding Batch.Breed}" FontSize="16" FontAttributes="Bold" TextColor="Black" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="{Binding Batch.AgeInDays, StringFormat='{0} días'}" FontSize="12" TextColor="#64748B" />
                        <Label Text="|" FontSize="12" TextColor="#CBD5E1" />
                        <Label Text="{Binding Batch.Quantity, StringFormat='{0} animales'}" FontSize="12" TextColor="#64748B" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <ScrollView Grid.Row="1" Padding="16">
            <VerticalStackLayout Spacing="16" x:Name="MainLayout">

                <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="{StaticResource CardBackground}" Padding="16">
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#E8F5E9" StrokeThickness="0" VerticalOptions="Center">
                                <Label Text="📈" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label Text="Peso promedio" FontSize="12" TextColor="#64748B" />
                                <Label Text="{Binding Batch.CurrentWeight, StringFormat='{0:F1}'}" FontSize="22" FontAttributes="Bold" TextColor="Black" />
                                <Label Text="kg" FontSize="11" TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="{StaticResource CardBackground}" Padding="16">
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="40" HeightRequest="40" StrokeShape="RoundRectangle 8" BackgroundColor="#FFF3E0" StrokeThickness="0" VerticalOptions="Center">
                                <Label Text="📅" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="12,0,0,0" VerticalOptions="Center">
                                <Label Text="Edad promedio" FontSize="12" TextColor="#64748B" />
                                <Label Text="{Binding Batch.AgeInDays}" FontSize="22" FontAttributes="Bold" TextColor="Black" />
                                <Label Text="días" FontSize="11" TextColor="#64748B" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1.5" Stroke="{StaticResource WarningOrange}" BackgroundColor="White" Padding="16">
                    <VerticalStackLayout Spacing="10">
                        <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                            <Label Text="⚠️" FontSize="16" TextColor="{StaticResource WarningOrange}"/>
                            <Label Text="Clasificación de Camada Requerida" FontSize="14" FontAttributes="Bold" TextColor="Black" />
                        </HorizontalStackLayout>
                        <Label Text="Este lote ha alcanzado la edad de selección. Divida el grupo para aplicar las guías específicas de vacunación y alimentación según su propósito." FontSize="12" TextColor="#475569" LineBreakMode="WordWrap" />
                        <Button Text="Clasificar y Dividir Lote" BackgroundColor="{StaticResource WarningOrange}" TextColor="White" FontAttributes="Bold" FontSize="13" CornerRadius="6" HeightRequest="38" Command="{Binding SplitBatchCommand}" />
                    </VerticalStackLayout>
                </Border>

                <Grid ColumnDefinitions="Auto, Auto, Auto" ColumnSpacing="24" HeightRequest="40" Margin="4,4,0,0">
                    <VerticalStackLayout Grid.Column="0" VerticalOptions="FillAndExpand">
                        <HorizontalStackLayout Spacing="6" VerticalOptions="Center" Margin="0,4">
                            <Label Text="💊" FontSize="14" TextColor="{StaticResource EmeraldMint}"/>
                            <Label Text="Vacunas" FontSize="14" FontAttributes="Bold" TextColor="{StaticResource EmeraldMint}"/>
                        </HorizontalStackLayout>
                        <BoxView HeightRequest="3" Color="{StaticResource EmeraldMint}" HorizontalOptions="FillAndExpand" Margin="0,4,0,0"/>
                    </VerticalStackLayout>

                    <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                        <Label Text="🍂" FontSize="14" TextColor="#475569"/>
                        <Label Text="Alimentación" FontSize="14" TextColor="#475569"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                        <Label Text="📈" FontSize="14" TextColor="#475569"/>
                        <Label Text="Animales" FontSize="14" TextColor="#475569"/>
                    </HorizontalStackLayout>
                </Grid>
                <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,-13,0,0" />

                <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="White" Padding="16">
                    <VerticalStackLayout Spacing="14">
                        <Label Text="Calendario de vacunación" FontSize="14" FontAttributes="Bold" TextColor="Black" />

                        <CollectionView ItemsSource="{Binding Vaccinations}">
                            <CollectionView.ItemsLayout>
                                <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:Vaccination">
                                    <Grid ColumnDefinitions="Auto, *, Auto" RowDefinitions="Auto, Auto, Auto" ColumnSpacing="12" Margin="0,0,0,4">

                                        <VerticalStackLayout Grid.Column="0" Grid.Row="0" Grid.RowSpan="3" HorizontalOptions="Center" WidthRequest="32">
                                            <Border WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 14" StrokeThickness="0">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Aplicada">
                                                        <Setter Property="BackgroundColor" Value="#E2F0D9" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Pendiente">
                                                        <Setter Property="BackgroundColor" Value="#FFF3CD" />
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Atrasada">
                                                        <Setter Property="BackgroundColor" Value="#FCE8E6" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding AppliedSymbol}" FontSize="12" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Aplicada">
                                                            <Setter Property="TextColor" Value="#2E7D32" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Pendiente">
                                                            <Setter Property="TextColor" Value="#B45309" />
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Atrasada">
                                                            <Setter Property="TextColor" Value="#C53929" />
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>
                                            <BoxView WidthRequest="3" HeightRequest="75" HorizontalOptions="Center" Color="#E2E9E5">
                                                <BoxView.Triggers>
                                                    <DataTrigger TargetType="BoxView" Binding="{Binding Status}" Value="Aplicada">
                                                        <Setter Property="Color" Value="#A3E635" />
                                                    </DataTrigger>
                                                </BoxView.Triggers>
                                            </BoxView>
                                        </VerticalStackLayout>

                                        <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="2" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold" TextColor="Black" />
                                            <Label Text="{Binding DayNumber, StringFormat='Día {0} (días)'}" FontSize="11" TextColor="#64748B" />
                                            <Label Text="Dosis inicial protectora ocular/agua contra Newcastle y Bronquitis." FontSize="12" TextColor="#64748B" LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>

                                        <Label Grid.Column="2" Grid.Row="0" Text="{Binding Status}" FontSize="12" FontAttributes="Bold" TextColor="Black" VerticalOptions="Start" HorizontalOptions="End" />

                                        <VerticalStackLayout Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" Padding="10" Spacing="8" BackgroundColor="#F8FAF9" Margin="0,8,0,12" IsVisible="False">
                                            <VerticalStackLayout.Triggers>
                                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding Status}" Value="Pendiente">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="VerticalStackLayout" Binding="{Binding Status}" Value="Atrasada">
                                                    <Setter Property="IsVisible" Value="True" />
                                                </DataTrigger>
                                            </VerticalStackLayout.Triggers>

                                            <Label Text="💉 Registrar Aplicación de Dosis:" FontSize="11" FontAttributes="Bold" TextColor="{StaticResource EmeraldMint}"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0">
                                                    <Label Text="Medicamento usado" FontSize="10" TextColor="#64748B" />
                                                    <Entry Text="{Binding CustomMedicationName}" Placeholder="Ej: Parvovac" HeightRequest="36" FontSize="12" BackgroundColor="White"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1">
                                                    <Label Text="Cantidad / Dosis" FontSize="10" TextColor="#64748B" />
                                                    <Entry Text="{Binding CustomDoseAmount}" Placeholder="Ej: 2 ml" HeightRequest="36" FontSize="12" BackgroundColor="White"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                            <Button Text="Confirmar Aplicación" HeightRequest="32" FontSize="11" FontAttributes="Bold" BackgroundColor="{StaticResource EmeraldMint}" TextColor="White" Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BatchDetailViewModel}}, Path=ApplyVaccinationCommand}" CommandParameter="{Binding .}" />
                                        </VerticalStackLayout>

                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <Border Grid.Row="2" StrokeThickness="1" Stroke="#E2E9E5" BackgroundColor="White" Padding="16,10" HeightRequest="68">
            <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="12">
                <Button Grid.Column="0" Text="📊 Exportar Excel" BackgroundColor="#2D6A4F" TextColor="White" FontAttributes="Bold" FontSize="13" HeightRequest="44" CornerRadius="22" Command="{Binding ExportCsvCommand}" />

                <Button Grid.Column="1" Text="📄 Ficha Imprimible" BackgroundColor="#0EA5E9" TextColor="White" FontAttributes="Bold" FontSize="13" HeightRequest="44" CornerRadius="22" Command="{Binding ExportHtmlCommand}" />

                <Button Grid.Column="2" Text="🗑️" BackgroundColor="{StaticResource ErrorRed}" TextColor="White" FontAttributes="Bold" FontSize="15" HeightRequest="44" WidthRequest="44" CornerRadius="22" Command="{Binding DeleteBatchCommand}" />
            </Grid>
        </Border>

    </Grid>
</ContentPage>