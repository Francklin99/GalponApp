<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:GalponApp.Presentation.ViewModels"
             xmlns:controls="clr-namespace:GalponApp.Presentation.Controls"
             xmlns:models="clr-namespace:GalponApp.Domain.Models"
             x:Class="GalponApp.Presentation.Views.BatchDetailPage"
             x:Name="DetailPage"

             Title="{Binding Title}"
             BackgroundColor="#F8FAFC">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="FarmGreen">#1B4332</Color>
            <Color x:Key="EmeraldMint">#2D6A4F</Color>
            <Color x:Key="LeafGreen">#40916C</Color>
            <Color x:Key="LightMint">#D8F3DC</Color>
            <Color x:Key="WarningOrange">#D97706</Color>
            <Color x:Key="ErrorRed">#E53935</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto" Padding="0">

        <!-- ══════════════════════════════════════ HEADER ══════════════════════════════════════ -->
        <Border Grid.Row="0" StrokeThickness="0" BackgroundColor="White" Padding="16,12">
            <Border.Shadow>
                <Shadow Brush="#1A000000" Offset="0,2" Radius="4" Opacity="0.08"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="Auto, *">
                <Button Grid.Column="0" Text="←" FontSize="20" FontAttributes="Bold"
                        BackgroundColor="Transparent" TextColor="#0F172A"
                        WidthRequest="40" HeightRequest="40"
                        Command="{Binding GoBackCommand}" VerticalOptions="Center"/>
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="8,0,0,0">
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="{Binding Batch.CategoryIcon}" FontSize="15"/>
                        <Label Text="{Binding Batch.Name}" FontSize="16" FontAttributes="Bold" TextColor="#0F172A"/>
                        <Label Text="·" FontSize="16" TextColor="#CBD5E1"/>
                        <Label Text="{Binding Batch.Breed}" FontSize="16" TextColor="#475569"/>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="8">
                        <Label Text="{Binding Batch.AgeInDays, StringFormat='{0} días'}" FontSize="12" TextColor="#94A3B8"/>
                        <Label Text="·" FontSize="12" TextColor="#CBD5E1"/>
                        <Label Text="{Binding Batch.Quantity, StringFormat='{0} animales'}" FontSize="12" TextColor="#94A3B8"/>
                        <Label Text="·" FontSize="12" TextColor="#CBD5E1"/>
                        <Label Text="{Binding Batch.Purpose}" FontSize="12" TextColor="#94A3B8"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════ CONTENIDO PRINCIPAL ══════════════════════════════════════ -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- MINI-STAT CARDS -->
                <Grid ColumnDefinitions="*, *" ColumnSpacing="10" Padding="16,16,16,10">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            BackgroundColor="White" Padding="14,12">
                        <Border.Shadow>
                            <Shadow Brush="#1A000000" Offset="0,1" Radius="4" Opacity="0.07"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#DCFCE7" StrokeThickness="0">
                                <Label Text="⚖️" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                                <Label Text="Peso prom." FontSize="11" TextColor="#94A3B8"/>
                                <HorizontalStackLayout Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Batch.CurrentWeight, StringFormat='{0:F1}'}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A"/>
                                    <Label Text="kg" FontSize="11" TextColor="#94A3B8" VerticalOptions="End" Margin="0,0,0,2"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            BackgroundColor="White" Padding="14,12">
                        <Border.Shadow>
                            <Shadow Brush="#1A000000" Offset="0,1" Radius="4" Opacity="0.07"/>
                        </Border.Shadow>
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0" WidthRequest="36" HeightRequest="36"
                                    StrokeShape="RoundRectangle 8" BackgroundColor="#FEF9C3" StrokeThickness="0">
                                <Label Text="📅" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Margin="10,0,0,0" VerticalOptions="Center">
                                <Label Text="Edad" FontSize="11" TextColor="#94A3B8"/>
                                <HorizontalStackLayout Spacing="3" VerticalOptions="Center">
                                    <Label Text="{Binding Batch.AgeInDays}" FontSize="20" FontAttributes="Bold" TextColor="#0F172A"/>
                                    <Label Text="días" FontSize="11" TextColor="#94A3B8" VerticalOptions="End" Margin="0,0,0,2"/>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </Grid>

                <!-- TARJETA DE DIVISIÓN (solo para lechones) -->
                <Border StrokeShape="RoundRectangle 10" StrokeThickness="1.5"
                        IsVisible="{Binding ShowDivisionCard}" Margin="16,0,16,10" Padding="16">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowDivisionPending}" Value="True">
                            <Setter Property="Stroke" Value="#E2E8F0"/>
                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowDivisionActive}" Value="True">
                            <Setter Property="Stroke" Value="#D97706"/>
                            <Setter Property="BackgroundColor" Value="#FFFBEB"/>
                        </DataTrigger>
                        <DataTrigger TargetType="Border" Binding="{Binding ShowDivisionUndo}" Value="True">
                            <Setter Property="Stroke" Value="#2D6A4F"/>
                            <Setter Property="BackgroundColor" Value="#F0FDF4"/>
                        </DataTrigger>
                    </Border.Triggers>
                    <Grid>
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowDivisionPending}" Opacity="0.55">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="🐷" FontSize="15"/>
                                <Label Text="Lote de Lechones — División Pendiente" FontSize="13" FontAttributes="Bold" TextColor="#475569"/>
                            </HorizontalStackLayout>
                            <Label Text="Complete el calendario de vacunación para habilitar la clasificación y división del lote." FontSize="12" TextColor="#64748B" LineBreakMode="WordWrap"/>
                            <Button Text="Clasificar y Dividir" BackgroundColor="#94A3B8" TextColor="White" FontSize="13" CornerRadius="6" HeightRequest="36" IsEnabled="False"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowDivisionActive}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="⚠️" FontSize="15"/>
                                <Label Text="Clasificación de Lechones Requerida" FontSize="13" FontAttributes="Bold" TextColor="#92400E"/>
                            </HorizontalStackLayout>
                            <Label Text="El lote ha alcanzado la edad de selección. Divida el grupo para aplicar guías específicas por propósito." FontSize="12" TextColor="#78350F" LineBreakMode="WordWrap"/>
                            <Button Text="Clasificar y Dividir Lote" BackgroundColor="#D97706" TextColor="White" FontAttributes="Bold" FontSize="13" CornerRadius="6" HeightRequest="36" Command="{Binding SplitBatchCommand}"/>
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="8" IsVisible="{Binding ShowDivisionUndo}">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="✅" FontSize="15"/>
                                <Label Text="División Realizada" FontSize="13" FontAttributes="Bold" TextColor="#2D6A4F"/>
                            </HorizontalStackLayout>
                            <Label Text="El lote fue clasificado y dividido. Si hubo un error, puede revertirlo." FontSize="12" TextColor="#475569" LineBreakMode="WordWrap"/>
                            <Button Text="↩ Volver a hacer la división" BackgroundColor="#E2E8F0" TextColor="#475569" FontAttributes="Bold" FontSize="13" CornerRadius="6" HeightRequest="36" Command="{Binding UndoSplitBatchCommand}"/>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- ══════════ PESTAÑAS ══════════ -->
                <Grid ColumnDefinitions="*, *, *" Padding="16,4,16,0" ColumnSpacing="0">
                    <!-- Tab: Vacunas -->
                    <VerticalStackLayout Grid.Column="0">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="Vacunas"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <HorizontalStackLayout Spacing="5" HorizontalOptions="Center" Padding="0,8">
                            <Label Text="💊" FontSize="13"/>
                            <Label Text="Vacunas" FontSize="13" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Vacunas">
                                        <Setter Property="TextColor" Value="#2D6A4F"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Alimentación">
                                        <Setter Property="TextColor" Value="#94A3B8"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Animales">
                                        <Setter Property="TextColor" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <BoxView HeightRequest="3" CornerRadius="2" HorizontalOptions="FillAndExpand">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Vacunas">
                                    <Setter Property="Color" Value="#2D6A4F"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Alimentación">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Animales">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                    </VerticalStackLayout>

                    <!-- Tab: Alimentación -->
                    <VerticalStackLayout Grid.Column="1">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="Alimentación"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <HorizontalStackLayout Spacing="5" HorizontalOptions="Center" Padding="0,8">
                            <Label Text="🌾" FontSize="13"/>
                            <Label Text="Alimentación" FontSize="13" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Alimentación">
                                        <Setter Property="TextColor" Value="#92400E"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Vacunas">
                                        <Setter Property="TextColor" Value="#94A3B8"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Animales">
                                        <Setter Property="TextColor" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <BoxView HeightRequest="3" CornerRadius="2" HorizontalOptions="FillAndExpand">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Alimentación">
                                    <Setter Property="Color" Value="#D97706"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Vacunas">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Animales">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                    </VerticalStackLayout>

                    <!-- Tab: Animales -->
                    <VerticalStackLayout Grid.Column="2">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SetTabCommand}" CommandParameter="Animales"/>
                        </VerticalStackLayout.GestureRecognizers>
                        <HorizontalStackLayout Spacing="5" HorizontalOptions="Center" Padding="0,8">
                            <Label Text="🐾" FontSize="13"/>
                            <Label Text="Animales" FontSize="13" FontAttributes="Bold">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Animales">
                                        <Setter Property="TextColor" Value="#1E40AF"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Vacunas">
                                        <Setter Property="TextColor" Value="#94A3B8"/>
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding ActiveTab}" Value="Alimentación">
                                        <Setter Property="TextColor" Value="#94A3B8"/>
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </HorizontalStackLayout>
                        <BoxView HeightRequest="3" CornerRadius="2" HorizontalOptions="FillAndExpand">
                            <BoxView.Triggers>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Animales">
                                    <Setter Property="Color" Value="#1D4ED8"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Vacunas">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                                <DataTrigger TargetType="BoxView" Binding="{Binding ActiveTab}" Value="Alimentación">
                                    <Setter Property="Color" Value="Transparent"/>
                                </DataTrigger>
                            </BoxView.Triggers>
                        </BoxView>
                    </VerticalStackLayout>
                </Grid>
                <BoxView HeightRequest="1" Color="#E2E8F0" Margin="0,0,0,12"/>

                <!-- ══════════════════════════════════════════════════════════════════════════════ -->
                <!--                          TAB: VACUNAS                                         -->
                <!-- ══════════════════════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="16,0" Spacing="10" IsVisible="{Binding IsVacunasTabVisible}">

                    <Label Text="Calendario de vacunación" FontSize="14" FontAttributes="Bold" TextColor="#0F172A"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Vaccinations}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Vaccination">
                                <Grid ColumnDefinitions="Auto, *" RowDefinitions="Auto, Auto" ColumnSpacing="12" Margin="0,0,0,12">

                                    <!-- Círculo de estado + línea -->
                                    <VerticalStackLayout Grid.Column="0" Grid.RowSpan="2" HorizontalOptions="Center" WidthRequest="32">
                                        <Border WidthRequest="28" HeightRequest="28" StrokeShape="RoundRectangle 14" StrokeThickness="0">
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Aplicada">
                                                    <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Pendiente">
                                                    <Setter Property="BackgroundColor" Value="#FEF9C3"/>
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Atrasada">
                                                    <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding AppliedSymbol}" FontSize="13" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold">
                                                <Label.Triggers>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Aplicada">
                                                        <Setter Property="TextColor" Value="#15803D"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Pendiente">
                                                        <Setter Property="TextColor" Value="#854D0E"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Atrasada">
                                                        <Setter Property="TextColor" Value="#991B1B"/>
                                                    </DataTrigger>
                                                </Label.Triggers>
                                            </Label>
                                        </Border>
                                        <BoxView WidthRequest="2" HeightRequest="60" HorizontalOptions="Center" Color="#E2E9E5">
                                            <BoxView.Triggers>
                                                <DataTrigger TargetType="BoxView" Binding="{Binding Status}" Value="Aplicada">
                                                    <Setter Property="Color" Value="#86EFAC"/>
                                                </DataTrigger>
                                            </BoxView.Triggers>
                                        </BoxView>
                                    </VerticalStackLayout>

                                    <!-- Info -->
                                    <VerticalStackLayout Grid.Column="1" Grid.Row="0" Spacing="3">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Label Grid.Column="0" Text="{Binding Name}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A"/>
                                            <Border Grid.Column="1" StrokeShape="RoundRectangle 5" StrokeThickness="0" Padding="6,2" VerticalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Aplicada">
                                                        <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Pendiente">
                                                        <Setter Property="BackgroundColor" Value="#FEF9C3"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Atrasada">
                                                        <Setter Property="BackgroundColor" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label Text="{Binding Status}" FontSize="10" FontAttributes="Bold">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Aplicada">
                                                            <Setter Property="TextColor" Value="#15803D"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Pendiente">
                                                            <Setter Property="TextColor" Value="#854D0E"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Atrasada">
                                                            <Setter Property="TextColor" Value="#991B1B"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>
                                        </Grid>
                                        <Label Text="{Binding DayNumber, StringFormat='Día {0}'}" FontSize="11" TextColor="#94A3B8"/>
                                        <Label Text="{Binding Description}" FontSize="12" TextColor="#64748B" LineBreakMode="WordWrap"/>
                                        <HorizontalStackLayout Spacing="5" Margin="0,3,0,0" IsVisible="{Binding HasCustomAppliedDose}">
                                            <Label Text="💉 Dosis aplicada:" FontSize="12" FontAttributes="Bold" TextColor="#C2410C" VerticalOptions="Center"/>
                                            <Label Text="{Binding CustomAppliedDoseDisplay}" FontSize="12" TextColor="#C2410C" FontAttributes="Bold" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Acciones -->
                                    <VerticalStackLayout Grid.Column="1" Grid.Row="1" Spacing="6" Margin="0,6,0,0">
                                        <!-- Cuando NO está aplicada -->
                                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="10" IsVisible="True">
                                            <Grid.Triggers>
                                                <DataTrigger TargetType="Grid" Binding="{Binding IsApplied}" Value="True">
                                                    <Setter Property="IsVisible" Value="False"/>
                                                </DataTrigger>
                                            </Grid.Triggers>
                                            <Border Grid.Column="0" StrokeShape="RoundRectangle 6" StrokeThickness="1.5" Stroke="#2D6A4F" BackgroundColor="#F0FDF4" Padding="12,6">
                                                <Border.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BatchDetailViewModel}}, Path=ApplyVaccinationCommand}" CommandParameter="{Binding .}"/>
                                                </Border.GestureRecognizers>
                                                <HorizontalStackLayout Spacing="5">
                                                    <Label Text="✓" FontSize="13" FontAttributes="Bold" TextColor="#2D6A4F" VerticalOptions="Center"/>
                                                    <Label Text="Marcar aplicada" FontSize="12" FontAttributes="Bold" TextColor="#2D6A4F" VerticalOptions="Center"/>
                                                </HorizontalStackLayout>
                                            </Border>
                                            <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                                <HorizontalStackLayout.GestureRecognizers>
                                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BatchDetailViewModel}}, Path=ToggleCustomFieldsCommand}" CommandParameter="{Binding .}"/>
                                                </HorizontalStackLayout.GestureRecognizers>
                                                <Border WidthRequest="16" HeightRequest="16" StrokeShape="RoundRectangle 3" StrokeThickness="1.5" VerticalOptions="Center">
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding ShowCustomFields}" Value="True">
                                                            <Setter Property="Stroke" Value="#2D6A4F"/>
                                                            <Setter Property="BackgroundColor" Value="#2D6A4F"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding ShowCustomFields}" Value="False">
                                                            <Setter Property="Stroke" Value="#94A3B8"/>
                                                            <Setter Property="BackgroundColor" Value="White"/>
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Label Text="✓" FontSize="10" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" IsVisible="{Binding ShowCustomFields}"/>
                                                </Border>
                                                <Label Text="Dosis diferente" FontSize="11" TextColor="#64748B" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Grid>

                                        <!-- Cuando YA está aplicada -->
                                        <Border StrokeShape="RoundRectangle 6" StrokeThickness="1" Stroke="#CBD5E1"
                                                BackgroundColor="#F8FAFC" Padding="10,5" HorizontalOptions="Start" IsVisible="False">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BatchDetailViewModel}}, Path=ApplyVaccinationCommand}" CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsApplied}" Value="True">
                                                    <Setter Property="IsVisible" Value="True"/>
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <HorizontalStackLayout Spacing="5">
                                                <Label Text="↩" FontSize="13" TextColor="#64748B" VerticalOptions="Center"/>
                                                <Label Text="Revertir" FontSize="12" TextColor="#64748B" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </Border>

                                        <!-- Panel dosis diferente -->
                                        <VerticalStackLayout Padding="10" Spacing="8" BackgroundColor="#F0FDF4" IsVisible="{Binding ShowCustomFields}">
                                            <Label Text="💉 Registrar medicamento alternativo" FontSize="11" FontAttributes="Bold" TextColor="#2D6A4F"/>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="8">
                                                <VerticalStackLayout Grid.Column="0">
                                                    <Label Text="Medicamento" FontSize="10" TextColor="#64748B"/>
                                                    <Entry Text="{Binding CustomMedicationName}" Placeholder="Ej: Parvovac" HeightRequest="36" FontSize="12" BackgroundColor="White"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1">
                                                    <Label Text="Dosis" FontSize="10" TextColor="#64748B"/>
                                                    <Entry Text="{Binding CustomDoseAmount}" Placeholder="Ej: 2 ml" HeightRequest="36" FontSize="12" BackgroundColor="White"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                            <Button Text="✓ Confirmar aplicación alternativa" HeightRequest="34" FontSize="11" FontAttributes="Bold"
                                                    BackgroundColor="#2D6A4F" TextColor="White" CornerRadius="6"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BatchDetailViewModel}}, Path=ApplyVaccinationCommand}"
                                                    CommandParameter="{Binding .}"/>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════════════════════════════════════════ -->
                <!--                       TAB: ALIMENTACIÓN                                       -->
                <!-- ══════════════════════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="16,0" Spacing="12" IsVisible="{Binding IsAlimentacionTabVisible}">

                    <!-- Guía por etapas (sin resumen extra) -->
                    <Label Text="Guía de alimentación por etapas" FontSize="14" FontAttributes="Bold" TextColor="#0F172A" Margin="0,4,0,0"/>

                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding FeedingStages}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="vm:FeedingStageItem">
                                <Border StrokeShape="RoundRectangle 10" StrokeThickness="1.5" Padding="0">
                                    <!-- Borde cambia según estado -->
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Current">
                                            <Setter Property="Stroke" Value="#D97706"/>
                                            <Setter Property="BackgroundColor" Value="#FFFBEB"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Past">
                                            <Setter Property="Stroke" Value="#E2E8F0"/>
                                            <Setter Property="BackgroundColor" Value="#F8FAFC"/>
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Future">
                                            <Setter Property="Stroke" Value="#DBEAFE"/>
                                            <Setter Property="BackgroundColor" Value="#EFF6FF"/>
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <VerticalStackLayout>
                                        <!-- Cabecera de la tarjeta (siempre visible) -->
                                        <Grid ColumnDefinitions="Auto, *, Auto" Padding="14,12" ColumnSpacing="10">
                                            <Grid.GestureRecognizers>
                                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:BatchDetailViewModel}}, Path=ToggleStageExpandedCommand}" CommandParameter="{Binding .}"/>
                                            </Grid.GestureRecognizers>
                                            <!-- Icono estado -->
                                            <Border Grid.Column="0" WidthRequest="34" HeightRequest="34" StrokeShape="RoundRectangle 8" StrokeThickness="0" VerticalOptions="Center">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Current">
                                                        <Setter Property="BackgroundColor" Value="#FDE68A"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Past">
                                                        <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                                                    </DataTrigger>
                                                    <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Future">
                                                        <Setter Property="BackgroundColor" Value="#DBEAFE"/>
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <Label HorizontalOptions="Center" VerticalOptions="Center" FontSize="16">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Current">
                                                            <Setter Property="Text" Value="🔆"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Past">
                                                            <Setter Property="Text" Value="✅"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Future">
                                                            <Setter Property="Text" Value="⏳"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </Border>
                                            <!-- Nombre y fechas -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                                <Label Text="{Binding StageName}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A"/>
                                                <Label Text="{Binding DateRangeText}" FontSize="11" TextColor="#64748B"/>
                                                <Label Text="{Binding DurationText}" FontSize="11" TextColor="#94A3B8"/>
                                            </VerticalStackLayout>
                                            <!-- Badge + flecha -->
                                            <VerticalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center" HorizontalOptions="End">
                                                <Border StrokeShape="RoundRectangle 5" StrokeThickness="0" Padding="6,2" HorizontalOptions="End">
                                                    <Border.Triggers>
                                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Current">
                                                            <Setter Property="BackgroundColor" Value="#FDE68A"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Past">
                                                            <Setter Property="BackgroundColor" Value="#DCFCE7"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Border" Binding="{Binding Status}" Value="Future">
                                                            <Setter Property="BackgroundColor" Value="#DBEAFE"/>
                                                        </DataTrigger>
                                                    </Border.Triggers>
                                                    <Label Text="{Binding StatusText}" FontSize="10" FontAttributes="Bold">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Current">
                                                                <Setter Property="TextColor" Value="#92400E"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Past">
                                                                <Setter Property="TextColor" Value="#15803D"/>
                                                            </DataTrigger>
                                                            <DataTrigger TargetType="Label" Binding="{Binding Status}" Value="Future">
                                                                <Setter Property="TextColor" Value="#1E40AF"/>
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </Border>
                                                <Label HorizontalOptions="End" FontSize="14" TextColor="#94A3B8">
                                                    <Label.Triggers>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                                            <Setter Property="Text" Value="▲"/>
                                                        </DataTrigger>
                                                        <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                                            <Setter Property="Text" Value="▼"/>
                                                        </DataTrigger>
                                                    </Label.Triggers>
                                                </Label>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Detalle expandible -->
                                        <VerticalStackLayout Padding="14,0,14,14" Spacing="10" IsVisible="{Binding IsExpanded}">
                                            <BoxView HeightRequest="1" Color="#E2E8F0"/>
                                            <!-- Alimento recomendado -->
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                    <Label Text="🌾 Tipo de alimento" FontSize="11" TextColor="#64748B"/>
                                                    <Label Text="{Binding Config.FeedType}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="⚖️ Por animal / día" FontSize="11" TextColor="#64748B"/>
                                                    <Label Text="{Binding Config.DailyAmountPerAnimal, StringFormat='{0:F2} kg'}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                                    <Label Text="🕐 Tomas al día" FontSize="11" TextColor="#64748B"/>
                                                    <Label Text="{Binding Config.FrequencyPerDay}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A"/>
                                                </VerticalStackLayout>
                                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                    <Label Text="💧 Agua / animal" FontSize="11" TextColor="#64748B"/>
                                                    <Label Text="{Binding Config.RecommendedWaterLiters, StringFormat='{0:F1} L'}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A"/>
                                                </VerticalStackLayout>
                                            </Grid>
                                            <!-- Info nutricional -->
                                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F1F5F9" Padding="12,10">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="📋 Información nutricional" FontSize="11" FontAttributes="Bold" TextColor="#475569"/>
                                                    <Label Text="{Binding Config.NutritionalInfo}" FontSize="12" TextColor="#64748B" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Border>
                                            <!-- Alternativas -->
                                            <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="#F0FDF4" Padding="12,10"
                                                    IsVisible="{Binding Config.Alternatives, Converter={x:Static vm:StringNotEmptyConverter.Instance}}">
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="🔄 Alimentos alternativos" FontSize="11" FontAttributes="Bold" TextColor="#2D6A4F"/>
                                                    <Label Text="{Binding Config.Alternatives}" FontSize="12" TextColor="#374151" LineBreakMode="WordWrap"/>
                                                </VerticalStackLayout>
                                            </Border>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <BoxView HeightRequest="16" Color="Transparent"/>
                </VerticalStackLayout>

                <!-- ══════════════════════════════════════════════════════════════════════════════ -->
                <!--                          TAB: ANIMALES                                        -->
                <!-- ══════════════════════════════════════════════════════════════════════════════ -->
                <VerticalStackLayout Padding="16,0" Spacing="12" IsVisible="{Binding IsAnimalesTabVisible}">

                    <!-- ─── 3 contadores de salud ─── -->
                    <Grid ColumnDefinitions="*, *, *" ColumnSpacing="8">
                        <!-- Saludable -->
                        <Border Grid.Column="0" StrokeShape="RoundRectangle 10" StrokeThickness="1.5"
                                Stroke="#86EFAC" BackgroundColor="#F0FDF4" Padding="10,12">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="💚" FontSize="20" HorizontalOptions="Center"/>
                                <Entry Text="{Binding HealthyCount, Mode=TwoWay}" Keyboard="Numeric"
                                       FontSize="18" FontAttributes="Bold" TextColor="#15803D"
                                       HorizontalTextAlignment="Center" WidthRequest="70" HeightRequest="36"
                                       BackgroundColor="White" Margin="0,2"/>
                                <Label Text="Saludables" FontSize="10" TextColor="#15803D" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <!-- En observación -->
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 10" StrokeThickness="1.5"
                                Stroke="#FDE68A" BackgroundColor="#FFFBEB" Padding="10,12">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🟡" FontSize="20" HorizontalOptions="Center"/>
                                <Entry Text="{Binding ObservingCount, Mode=TwoWay}" Keyboard="Numeric"
                                       FontSize="18" FontAttributes="Bold" TextColor="#92400E"
                                       HorizontalTextAlignment="Center" WidthRequest="70" HeightRequest="36"
                                       BackgroundColor="White" Margin="0,2"/>
                                <Label Text="En observ." FontSize="10" TextColor="#92400E" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                        <!-- Enfermos -->
                        <Border Grid.Column="2" StrokeShape="RoundRectangle 10" StrokeThickness="1.5"
                                Stroke="#FECACA" BackgroundColor="#FFF1F2" Padding="10,12">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="🔴" FontSize="20" HorizontalOptions="Center"/>
                                <Entry Text="{Binding SickCount, Mode=TwoWay}" Keyboard="Numeric"
                                       FontSize="18" FontAttributes="Bold" TextColor="#991B1B"
                                       HorizontalTextAlignment="Center" WidthRequest="70" HeightRequest="36"
                                       BackgroundColor="White" Margin="0,2"/>
                                <Label Text="Enfermos" FontSize="10" TextColor="#991B1B" HorizontalOptions="Center"/>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Panel de Guardar Distribución -->
                    <VerticalStackLayout Spacing="4" HorizontalOptions="FillAndExpand" Margin="0,4,0,0">
                        <Label Text="{Binding DistributionWarningText}" TextColor="#D97706" FontSize="11" FontAttributes="Bold" 
                               HorizontalOptions="Center" HorizontalTextAlignment="Center"
                               IsVisible="{Binding IsDistributionInvalid}"/>
                        
                        <Button Text="💾 Guardar Distribución de Salud" 
                                BackgroundColor="#2D6A4F" TextColor="White" 
                                CornerRadius="8" HeightRequest="38" FontSize="12" FontAttributes="Bold"
                                Command="{Binding ApplyDistributionCommand}"
                                IsEnabled="{Binding IsDistributionValid}"/>
                    </VerticalStackLayout>

                    <!-- ─── Info total animales ─── -->
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0"
                            BackgroundColor="#F8FAFC" Padding="12,8" IsVisible="{Binding ShowAnimalesLimit}">
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="⚠️" FontSize="14" VerticalOptions="Center"/>
                            <Label Text="{Binding AnimalesInfoText}" FontSize="12" TextColor="#475569"
                                   FontAttributes="Bold" VerticalOptions="Center" LineBreakMode="WordWrap"/>
                        </HorizontalStackLayout>
                    </Border>

                    <!-- ─── Encabezado lista + acción grupal ─── -->
                    <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10">
                        <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                            <Label Text="Lista de animales" FontSize="14" FontAttributes="Bold" TextColor="#0F172A"/>
                            <Label Text="{Binding AnimalesInfoText}" FontSize="11" TextColor="#94A3B8"/>
                        </VerticalStackLayout>
                        <Border Grid.Column="1" StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0" BackgroundColor="White" Padding="10,6">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding SetAllAnimalsStatusCommand}"/>
                            </Border.GestureRecognizers>
                            <HorizontalStackLayout Spacing="5">
                                <Label Text="⚕️" FontSize="12"/>
                                <Label Text="Estado grupal" FontSize="12" TextColor="#475569"/>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Lista de animales -->
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Animals}" Spacing="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="models:Animal">
                                <Frame CornerRadius="10" BorderColor="#E2E8F0" HasShadow="False"
                                       BackgroundColor="White" Padding="14,12" Margin="0,0,0,6">
                                    <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">

                                        <!-- Icono de estado -->
                                        <Frame Grid.Column="0" WidthRequest="40" HeightRequest="40"
                                               CornerRadius="20" BorderColor="Transparent" HasShadow="False"
                                               BackgroundColor="{Binding StatusBg}" VerticalOptions="Center" Padding="0">
                                            <Label Text="{Binding StatusIcon}" FontSize="18"
                                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                                        </Frame>

                                        <!-- Nombre + badge estado + peso -->
                                        <VerticalStackLayout Grid.Column="1" Spacing="3" VerticalOptions="Center">
                                            <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold" TextColor="#0F172A"/>
                                            <HorizontalStackLayout Spacing="8">
                                                <Frame CornerRadius="4" BorderColor="Transparent" HasShadow="False"
                                                       BackgroundColor="{Binding StatusBg}" Padding="6,2" VerticalOptions="Center">
                                                    <Label Text="{Binding Status}" FontSize="10" FontAttributes="Bold"
                                                           TextColor="{Binding StatusTextColor}"/>
                                                </Frame>
                                                <Label Text="{Binding Weight, StringFormat='{0:F1} kg'}"
                                                       FontSize="11" TextColor="#94A3B8" VerticalOptions="Center"/>
                                            </HorizontalStackLayout>
                                        </VerticalStackLayout>

                                        <!-- Acciones -->
                                        <HorizontalStackLayout Grid.Column="2" Spacing="8" VerticalOptions="Center">
                                            <!-- Renombrar -->
                                            <Frame CornerRadius="8" BorderColor="#E2E8F0" HasShadow="False"
                                                   BackgroundColor="#F8FAFC" Padding="9,7" VerticalOptions="Center">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding BindingContext.RenameAnimalCommand, Source={x:Reference DetailPage}}"
                                                        CommandParameter="{Binding .}"/>
                                                </Frame.GestureRecognizers>
                                                <Label Text="✏️" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Frame>
                                            <!-- Cambiar estado -->
                                            <Frame CornerRadius="8" BorderColor="#E2E8F0" HasShadow="False"
                                                   BackgroundColor="#F8FAFC" Padding="9,7" VerticalOptions="Center">
                                                <Frame.GestureRecognizers>
                                                    <TapGestureRecognizer
                                                        Command="{Binding BindingContext.ChangeAnimalStatusCommand, Source={x:Reference DetailPage}}"
                                                        CommandParameter="{Binding .}"/>
                                                </Frame.GestureRecognizers>
                                                <Label Text="⚕️" FontSize="14" HorizontalOptions="Center" VerticalOptions="Center"/>
                                            </Frame>
                                        </HorizontalStackLayout>
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <BoxView HeightRequest="16" Color="Transparent"/>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </ScrollView>

        <!-- ══════════════════════════════════════ BOTTOM BAR ══════════════════════════════════════ -->
        <Border Grid.Row="2" StrokeThickness="0" BackgroundColor="White" Padding="16,10" HeightRequest="68">
            <Border.Shadow>
                <Shadow Brush="#1A000000" Offset="0,-2" Radius="4" Opacity="0.07"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*, *, Auto" ColumnSpacing="10">
                <Button Grid.Column="0" Text="📊 Exportar Excel" BackgroundColor="#2D6A4F" TextColor="White"
                        FontAttributes="Bold" FontSize="12" HeightRequest="44" CornerRadius="22"
                        Command="{Binding ExportCsvCommand}"/>
                <Button Grid.Column="1" Text="📄 Ficha Imprimible" BackgroundColor="#0EA5E9" TextColor="White"
                        FontAttributes="Bold" FontSize="12" HeightRequest="44" CornerRadius="22"
                        Command="{Binding ExportHtmlCommand}"/>
                <Button Grid.Column="2" Text="🗑️" BackgroundColor="#E53935" TextColor="White"
                        FontAttributes="Bold" FontSize="15" HeightRequest="44" WidthRequest="44"
                        CornerRadius="22" Command="{Binding DeleteBatchCommand}"/>
            </Grid>
        </Border>

    </Grid>
</ContentPage>