<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="GalponApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:GalponApp.Presentation.Views"
    Title="Granja El Amigo"
    Shell.BackgroundColor="White"
    Shell.ForegroundColor="#1B4332"
    Shell.TitleColor="#1B4332"
    Shell.NavBarHasShadow="True"
    FlyoutBehavior="Disabled">

    <Shell.TitleView>
        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10" Padding="12,0,12,0" VerticalOptions="Center">
            <!-- Logo de la granja (Cerdo premium) -->
            <Border Grid.Column="0" WidthRequest="56" HeightRequest="56" StrokeShape="RoundRectangle 28" StrokeThickness="1.5" Stroke="#E2E8F0" BackgroundColor="White" VerticalOptions="Center">
                <Image Source="farm_logo.jpg" Aspect="AspectFit" Margin="1" />
            </Border>

            <!-- Nombre de la Granja -->
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="0">
                <Label Text="Granja El Amigo" FontSize="15" FontAttributes="Bold" TextColor="#1B4332" />
                <Label Text="Sistema de Control" FontSize="9.5" TextColor="#64748B" />
            </VerticalStackLayout>
            
            <Label Grid.Column="2" Text="🚜" FontSize="18" VerticalOptions="Center" Margin="0,0,8,0" />
        </Grid>
    </Shell.TitleView>

    <Shell.Resources>
        <ResourceDictionary>
            <Color x:Key="PrimaryGreen">#2E7D32</Color>
            <Style TargetType="TabBar" ApplyToDerivedTypes="True">
                <Setter Property="Shell.TabBarTitleColor" Value="{StaticResource PrimaryGreen}" />
                <Setter Property="Shell.TabBarUnselectedColor" Value="#64748B" />
                <Setter Property="Shell.TabBarBackgroundColor" Value="#FFFFFF" />
            </Style>
        </ResourceDictionary>
    </Shell.Resources>

    <TabBar>
        <Tab Title="Inicio" Icon="home_tab.png">
            <ShellContent ContentTemplate="{DataTemplate views:DashboardPage}" Route="DashboardPage" />
        </Tab>
        <Tab Title="Lotes" Icon="lotes_tab.png">
            <ShellContent ContentTemplate="{DataTemplate views:BatchListPage}" Route="BatchListPage" />
        </Tab>
        <Tab Title="Alertas" Icon="alerts_tab.png">
            <ShellContent ContentTemplate="{DataTemplate views:AlertsPage}" Route="AlertsPage" />
        </Tab>
        <Tab Title="Ayuda" Icon="help_tab.png">
            <ShellContent ContentTemplate="{DataTemplate views:HelpCenterPage}" Route="HelpCenterPage" />
        </Tab>
        <Tab Title="Reportes" Icon="reports_tab.png">
            <ShellContent ContentTemplate="{DataTemplate views:ReportsPage}" Route="ReportsPage" />
        </Tab>
    </TabBar>

</Shell>
